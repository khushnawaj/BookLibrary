# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/shelfforge

# ─── JWT Secrets (use long random strings — min 32 chars each) ────────────────
JWT_ACCESS_SECRET=replace_with_a_very_long_random_secret_string_here_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_very_long_random_secret_string_here

# ─── Token Expiry ──────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (Frontend URL) ───────────────────────────────────────────────────────
# Dev: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ─── Cookie Configuration ──────────────────────────────────────────────────────
# Dev: leave unset (defaults to lax)
# Production - same domain:   strict
# Production - cross domain (e.g. Vercel + Render): none
#   NOTE: sameSite=none REQUIRES secure=true (HTTPS only)
# COOKIE_SAME_SITE=none

# ─── Google Books API ──────────────────────────────────────────────────────────
# Get a free key at: https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=

# ─── Cloudinary (Image Uploads) ────────────────────────────────────────────────
# Sign up free at: https://cloudinary.com
# Required for book cover uploads in production (local /uploads won't persist)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
